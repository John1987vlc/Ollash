# Normalize line endings to LF in the repository (eol=lf on checkout for all text files)
* text=auto eol=lf

# Python
*.py text eol=lf
*.pyi text eol=lf

# JavaScript / TypeScript
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.jsx text eol=lf
*.json text eol=lf

# Config / markup
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.html text eol=lf
*.css text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.txt text eol=lf

# Shell scripts
*.sh text eol=lf

# Binaries — do not touch
*.png binary
*.jpg binary
*.ico binary
*.woff2 binary
*.woff binary
*.ttf binary
*.eot binary
*.pdf binary
*.zip binary
*.gz binary
